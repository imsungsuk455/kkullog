---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout pt-8">
    <section id="hero" class="mb-10">
      <div class="modern-card" style="padding: 3rem 2rem;">
        <h1 class="text-4xl font-extrabold text-accent sm:text-5xl mb-6">
            {SITE.author}
        </h1>
        <p class="text-lg leading-relaxed text-slate-600 dark:text-slate-400">
            {SITE.desc}
        </p>
        <div class="mt-8">
            <LinkButton href="/posts/" class="btn inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-xl hover:opacity-90 transition-all shadow-lg shadow-accent/20">
                모든 글 읽어보기
                <IconArrowRight class="w-5 h-5" />
            </LinkButton>
        </div>
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pb-12">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold tracking-tight text-foreground flex items-center gap-3">
                <span class="w-8 h-1 bg-accent rounded-full"></span>
                최신 포스트
            </h2>
            <LinkButton href="/posts/" class="text-accent text-sm font-semibold hover:underline">
                전체 보기
            </LinkButton>
          </div>
          <ul class="grid grid-cols-1 gap-3">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && (
                  <li class="hover:translate-x-1 transition-transform duration-200">
                    <Card variant="h3" {...data} />
                  </li>
                )
            )}
          </ul>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
